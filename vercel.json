{
  "cleanUrls": true,
  "routes": [
    { "src": "/api/waitlist", "dest": "/api/waitlist" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/logo.svg", "dest": "/logo.svg" },
    { "src": "/favicon.svg", "dest": "/favicon.svg" },
    { "src": "/[^.]*", "dest": "/index.html" }
  ]
}
