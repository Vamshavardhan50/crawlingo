{
  "name": "crawlingo",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Crawlingo - next-generation web scraping and monitoring framework",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "napi": {
    "name": "crawlingo-native",
    "triples": {
      "defaults": true,
      "additional": []
    }
  },
  "scripts": {
    "build": "npm run build:native && npm run build:ts && node scripts/copy-native-assets.cjs",
    "build:native": "napi build --platform --release --js src/native.js --dts src/native.d.ts --cargo-cwd native .",
    "build:debug": "napi build --platform --js src/native.js --dts src/native.d.ts --cargo-cwd native .",
    "prepack": "npm run build:ts && node scripts/copy-native-assets.cjs",
    "build:ts": "tsc",
    "lint": "tsc --noEmit",
    "test": "node tests/smoke.cjs",
    "test:amazon": "node tests/amazon-scrape.cjs",
    "test:all": "node tests/test_all_apis.cjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^25.9.3",
    "typescript": "^5.4.5"
  }
}
