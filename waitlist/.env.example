# SMTP settings for dispatching waitlist sign-up confirmation emails
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-google-app-password

# Google Sheets Webhook url for syncing sign-up details
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec

# WhatsApp community group link for new members
WHATSAPP_GROUP_LINK=https://chat.whatsapp.com/your-group-id
