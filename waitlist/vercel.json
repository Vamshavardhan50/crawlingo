{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/docs",
      "destination": "https://crawlingo-docs.vercel.app/"
    },
    {
      "source": "/docs/:path*",
      "destination": "https://crawlingo-docs.vercel.app/:path*"
    },
    {
      "source": "/((?!api/|docs/).*)",
      "destination": "/index.html"
    }
  ]
}
